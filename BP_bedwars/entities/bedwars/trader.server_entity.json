{
    "format_version": "1.21.0",
    "minecraft:entity": {
        "description": {
            "identifier": "bedwars:trader",
            "is_spawnable": true,
            "is_summonable": true,
            "is_experimental": false,
            "properties": {
                "bedwars:trader_skin": { "client_sync": true, "type": "int", "range": [0, 21], "default": 0 },
                "bedwars:trader_geometry": { "client_sync": true, "type": "enum", "values": ["default", "slim"], "default": "default" },
                "bedwars:trader_type": { "type": "enum", "values": ["item", "upgrade"], "default": "item" }
            }
