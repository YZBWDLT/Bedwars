{
    "format_version": "1.21.0",
    "minecraft:entity": {
        "description": {
            "identifier": "minecraft:player",
            "is_spawnable": false,
            "is_summonable": false,
            "is_experimental": false,
            "properties": {
                "bedwars:is_invisible": {
                    "type": "bool",
                    "default": false,
                    "client_sync": true
                },
                "bedwars:team": {
                    "type": "enum",
                    "values": ["none", "red", "blue", "green", "yellow", "white", "pink", "gray", "cyan", "brown", "purple", "orange"],
                    "default": "none"
                }
            },
            "scripts": { "animate": [ "is_invisibility_test" ] },
            "animations": { "is_invisibility_test": "controller.animation.player.is_invisibility_test" }
        },

        "components": {
            "minecraft:experience_reward": { "on_death": "Math.Min(query.player_level * 7, 100)" },
            "minecraft:type_family": { "family": [ "player" ] },
            "minecraft:is_hidden_when_invisible": { },
            "minecraft:loot": { "table": "loot_tables/empty.json" },
            "minecraft:collision_box": { "width": 0.6, "height": 1.8 },
            "minecraft:can_climb": { },
            "minecraft:movement": { "value": 0.1 },
            "minecraft:hurt_on_condition": { "damage_conditions": [ { "filters": { "test": "in_lava", "subject": "self", "operator": "==", "value": true }, "cause": "lava", "damage_per_tick": 4 } ] },
            "minecraft:attack": { "damage": 1 },
            "minecraft:exhaustion_values": { "heal": 6, "jump": 0.05, "sprint_jump": 0.2, "mine": 0.005, "attack": 0.1, "damage": 0.1, "walk": 0.0, "sprint": 0.01, "swim": 0.01 },
            "minecraft:player.saturation": { "value": 5, "max": 20 },
            "minecraft:player.exhaustion": { "value": 0, "max": 20 },
            "minecraft:player.level": { "value": 0, "max": 24791 },
            "minecraft:player.experience": { "value": 0, "max": 1 },
            "minecraft:breathable": { "total_supply": 15, "suffocate_time": -1, "inhale_time": 3.75, "generates_bubbles": false },
            "minecraft:nameable": { "always_show": true, "allow_name_tag_renaming": false },
            "minecraft:physics": { },
            "minecraft:pushable": { "is_pushable": false, "is_pushable_by_piston": true },
            "minecraft:insomnia": { "days_until_insomnia": 3 },
            "minecraft:rideable": { "seat_count": 2, "family_types": [ "parrot_tame" ], "pull_in_entities": true, "seats": [ { "position": [ 0.4, -0.2, -0.1 ], "min_rider_count": 0, "max_rider_count": 0, "lock_rider_rotation": 0 }, { "position": [ -0.4, -0.2, -0.1 ], "min_rider_count": 1, "max_rider_count": 2, "lock_rider_rotation": 0 } ] },
            "minecraft:conditional_bandwidth_optimization": { },
            "minecraft:block_climber": {},
            "minecraft:environment_sensor": { "triggers": { "filters": { "all_of": [ { "test": "has_mob_effect", "subject": "self", "value": "bad_omen" }, { "test": "is_in_village", "subject": "self", "value": true } ] }, "event": "minecraft:trigger_raid" } },

            "minecraft:damage_sensor": {
                "triggers": [
                    { "on_damage": { "filters": { "all_of": [ { "test": "enum_property", "domain": "bedwars:team", "value": "red", "subject": "self" }, { "test": "enum_property", "domain": "bedwars:team", "value": "red", "subject": "other" } ] } }, "deals_damage": false },
                    { "on_damage": { "filters": { "all_of": [ { "test": "enum_property", "domain": "bedwars:team", "value": "blue", "subject": "self" }, { "test": "enum_property", "domain": "bedwars:team", "value": "blue", "subject": "other" } ] } }, "deals_damage": false },
                    { "on_damage": { "filters": { "all_of": [ { "test": "enum_property", "domain": "bedwars:team", "value": "green", "subject": "self" }, { "test": "enum_property", "domain": "bedwars:team", "value": "green", "subject": "other" } ] } }, "deals_damage": false },
                    { "on_damage": { "filters": { "all_of": [ { "test": "enum_property", "domain": "bedwars:team", "value": "yellow", "subject": "self" }, { "test": "enum_property", "domain": "bedwars:team", "value": "yellow", "subject": "other" } ] } }, "deals_damage": false },
                    { "on_damage": { "filters": { "all_of": [ { "test": "enum_property", "domain": "bedwars:team", "value": "white", "subject": "self" }, { "test": "enum_property", "domain": "bedwars:team", "value": "white", "subject": "other" } ] } }, "deals_damage": false },
                    { "on_damage": { "filters": { "all_of": [ { "test": "enum_property", "domain": "bedwars:team", "value": "pink", "subject": "self" }, { "test": "enum_property", "domain": "bedwars:team", "value": "pink", "subject": "other" } ] } }, "deals_damage": false },
                    { "on_damage": { "filters": { "all_of": [ { "test": "enum_property", "domain": "bedwars:team", "value": "gray", "subject": "self" }, { "test": "enum_property", "domain": "bedwars:team", "value": "gray", "subject": "other" } ] } }, "deals_damage": false },
                    { "on_damage": { "filters": { "all_of": [ { "test": "enum_property", "domain": "bedwars:team", "value": "cyan", "subject": "self" }, { "test": "enum_property", "domain": "bedwars:team", "value": "cyan", "subject": "other" } ] } }, "deals_damage": false },
                    { "on_damage": { "filters": { "all_of": [ { "test": "enum_property", "domain": "bedwars:team", "value": "brown", "subject": "self" }, { "test": "enum_property", "domain": "bedwars:team", "value": "brown", "subject": "other" } ] } }, "deals_damage": false },
                    { "on_damage": { "filters": { "all_of": [ { "test": "enum_property", "domain": "bedwars:team", "value": "purple", "subject": "self" }, { "test": "enum_property", "domain": "bedwars:team", "value": "purple", "subject": "other" } ] } }, "deals_damage": false },
                    { "on_damage": { "filters": { "all_of": [ { "test": "enum_property", "domain": "bedwars:team", "value": "orange", "subject": "self" }, { "test": "enum_property", "domain": "bedwars:team", "value": "orange", "subject": "other" } ] } }, "deals_damage": false }
                ]
            }
        },

        "events": {
            "minecraft:gain_bad_omen": { "add": { "component_groups": [ "minecraft:add_bad_omen" ] } },
            "minecraft:clear_add_bad_omen": { "remove": { "component_groups": [ "minecraft:add_bad_omen" ] }, "add": { "component_groups": [ "minecraft:clear_bad_omen_spell_effect" ] } },
            "minecraft:trigger_raid": { "add": { "component_groups": [ "minecraft:raid_trigger" ] } },
            "minecraft:remove_raid_trigger": { "remove": { "component_groups": [ "minecraft:raid_trigger" ] } },

            "team_red": { "set_property": { "bedwars:team": "red" } },
            "team_blue": { "set_property": { "bedwars:team": "blue" } },
            "team_green": { "set_property": { "bedwars:team": "green" } },
            "team_yellow": { "set_property": { "bedwars:team": "yellow" } },
            "team_white": { "set_property": { "bedwars:team": "white" } },
            "team_pink": { "set_property": { "bedwars:team": "pink" } },
            "team_gray": { "set_property": { "bedwars:team": "gray" } },
            "team_cyan": { "set_property": { "bedwars:team": "cyan" } },
            "team_brown": { "set_property": { "bedwars:team": "brown" } },
            "team_purple": { "set_property": { "bedwars:team": "purple" } },
            "team_orange": { "set_property": { "bedwars:team": "orange" } },
            "remove_team": { "set_property": { "bedwars:team": "none" } },

            "hide_armor": { "set_property": { "bedwars:is_invisible": true } },
            "show_armor": { "set_property": { "bedwars:is_invisible": false } }
        },

        "component_groups": {
            "minecraft:add_bad_omen": {
                "minecraft:spell_effects": { "add_effects": [ { "effect": "bad_omen", "duration": 6000, "visible": false, "display_on_screen_animation": true } ] },
                "minecraft:timer": { "time": [ 0.0, 0.0 ], "looping": false, "time_down_event": { "event": "minecraft:clear_add_bad_omen", "target": "self" } }
            },
            "minecraft:clear_bad_omen_spell_effect": {
                "minecraft:spell_effects": { }
            },
            "minecraft:raid_trigger": {
                "minecraft:raid_trigger": { "triggered_event": { "event": "minecraft:remove_raid_trigger", "target": "self" } },
                "minecraft:spell_effects": { "remove_effects": "bad_omen" }
            }
        }
    }
}




